# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# ===========================================================================
# Supabase — database + auth
# ===========================================================================
# Find these in your Supabase dashboard: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# Service-role key is server-only. Used for admin tasks (creating client logins, etc.).
# NEVER expose this to the browser. No NEXT_PUBLIC_ prefix on purpose.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# ===========================================================================
# Google OAuth — reading client Mainsheets (read-only access)
# ===========================================================================
# Create at: console.cloud.google.com → Credentials → "Create OAuth Client ID"
# Application type: Web application
# Authorized redirect URIs:
#   - http://localhost:3000/api/auth/google/callback   (local dev)
#   - https://<your-vercel-url>/api/auth/google/callback  (production, add later)
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# The redirect URI must match one of the authorized URIs above exactly.
# For local dev use the localhost variant. For production set it to your Vercel URL.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
